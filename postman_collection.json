{
  "info": {
    "name": "BAOCAO API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "ROLES",
      "item": [
        {
          "name": "GET all roles",
          "request": {
            "method": "GET",
            "url": "http://localhost:3000/api/v1/roles"
          }
        },
        {
          "name": "GET role by id",
          "request": {
            "method": "GET",
            "url": "http://localhost:3000/api/v1/roles/{{role_id}}"
          }
        },
        {
          "name": "POST create role ADMIN",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "http://localhost:3000/api/v1/roles",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"ADMIN\",\n  \"description\": \"Quản trị viên\"\n}"
            }
          }
        },
        {
          "name": "POST create role USER",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "http://localhost:3000/api/v1/roles",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"USER\",\n  \"description\": \"Người dùng thường\"\n}"
            }
          }
        },
        {
          "name": "PUT update role",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "http://localhost:3000/api/v1/roles/{{role_id}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"description\": \"Mô tả đã cập nhật\"\n}"
            }
          }
        },
        {
          "name": "DELETE role (soft delete)",
          "request": {
            "method": "DELETE",
            "url": "http://localhost:3000/api/v1/roles/{{role_id}}"
          }
        }
      ]
    },
    {
      "name": "AUTH",
      "item": [
        {
          "name": "POST register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "http://localhost:3000/api/v1/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"Admin@123\",\n  \"email\": \"admin@test.com\",\n  \"role\": \"{{role_id}}\"\n}"
            }
          }
        },
        {
          "name": "POST login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "http://localhost:3000/api/v1/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"Admin@123\"\n}"
            }
          }
        },
        {
          "name": "GET me",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "http://localhost:3000/api/v1/auth/me"
          }
        },
        {
          "name": "POST logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "http://localhost:3000/api/v1/auth/logout"
          }
        }
      ]
    },
    {
      "name": "USERS",
      "item": [
        {
          "name": "GET all users",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "http://localhost:3000/api/v1/users"
          }
        },
        {
          "name": "GET user by id",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "http://localhost:3000/api/v1/users/{{user_id}}"
          }
        },
        {
          "name": "POST create user",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "http://localhost:3000/api/v1/users",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"user1\",\n  \"password\": \"User@123\",\n  \"email\": \"user1@test.com\",\n  \"role\": \"{{role_id}}\",\n  \"fullName\": \"Nguyen Van A\"\n}"
            }
          }
        },
        {
          "name": "PUT update user",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "http://localhost:3000/api/v1/users/{{user_id}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Nguyen Van B\"\n}"
            }
          }
        },
        {
          "name": "DELETE user (soft delete)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "http://localhost:3000/api/v1/users/{{user_id}}"
          }
        }
      ]
    },
    {
      "name": "PRODUCTS",
      "item": [
        {
          "name": "GET all products",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:3000/api/v1/products?title=&minPrice=0&maxPrice=1000000&page=1&limit=5",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "v1", "products"],
              "query": [
                { "key": "title", "value": "" },
                { "key": "minPrice", "value": "0" },
                { "key": "maxPrice", "value": "1000000" },
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "5" }
              ]
            }
          }
        },
        {
          "name": "GET product by id",
          "request": {
            "method": "GET",
            "url": "http://localhost:3000/api/v1/products/{{product_id}}"
          }
        },
        {
          "name": "POST create product",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "http://localhost:3000/api/v1/products",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Áo Thun Nam\",\n  \"sku\": \"ATN-001\",\n  \"description\": \"Áo thun nam chất liệu cotton\",\n  \"price\": 150000,\n  \"category\": \"Áo\",\n  \"images\": [\"https://example.com/image1.jpg\"],\n  \"stock\": 100\n}"
            }
          }
        },
        {
          "name": "PUT update product",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "http://localhost:3000/api/v1/products/{{product_id}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"price\": 180000,\n  \"description\": \"Mô tả đã cập nhật\"\n}"
            }
          }
        },
        {
          "name": "DELETE product (soft delete)",
          "request": {
            "method": "DELETE",
            "url": "http://localhost:3000/api/v1/products/{{product_id}}"
          }
        },
        {
          "name": "GET search products by title",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:3000/api/v1/products?title=áo&page=1&limit=10",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "v1", "products"],
              "query": [
                { "key": "title", "value": "áo" },
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "GET filter products by price",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:3000/api/v1/products?minPrice=100000&maxPrice=300000",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "v1", "products"],
              "query": [
                { "key": "minPrice", "value": "100000" },
                { "key": "maxPrice", "value": "300000" }
              ]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "role_id",
      "value": "PASTE_ROLE_ID_HERE",
      "description": "Thay bằng _id của role sau khi tạo"
    },
    {
      "key": "user_id",
      "value": "PASTE_USER_ID_HERE",
      "description": "Thay bằng _id của user sau khi tạo"
    },
    {
      "key": "token",
      "value": "PASTE_TOKEN_HERE",
      "description": "Thay bằng token nhận được sau khi login"
    },
    {
      "key": "product_id",
      "value": "PASTE_PRODUCT_ID_HERE",
      "description": "Thay bằng _id của product sau khi tạo"
    }
  ]
}
