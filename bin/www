var app = require('../app');
var http = require('http');
var jwt = require('jsonwebtoken');
let userModel = require('../schemas/users');
let chatsService = require('../services/chats.service');
let { Server } = require('socket.io');
let notificationsService = require('../services/notifications.service');

const JWT_SECRET = 'BAOCAOCHIUTHU4';

var port = process.env.PORT || 3000;
app.set('port', port);

var server = http.createServer(app);

let io = new Server(server, {
    cors: {
        origin: '*'
    }
});

io.use(async function (socket, next) {
    try {
        let token = socket.handshake.auth.token;
        if (!token) {
            return next(new Error('Ban chua dang nhap'));
        }

        let result = jwt.verify(token, JWT_SECRET);
        let user = await userModel.findById(result.id).populate('role');

        if (!user) {
            return next(new Error('Khong tim thay user'));
        }

        socket.userId = user._id.toString();
        socket.roleName = user.role.name;
        socket.displayName = user.fullName || user.username || 'User';
        next();
    } catch (err) {
        next(new Error('Token khong hop le hoac da het han'));
    }
});

io.on('connection', function (socket) {
    console.log('Socket da ket noi:', socket.userId, '-', socket.roleName);

    let notificationRoomName = 'notification_' + socket.userId;
    socket.join(notificationRoomName);
    if (socket.roleName === 'ADMIN') {
        socket.join('notification_admins');
    }

    if (socket.roleName === 'USER') {
        let roomName = 'user_' + socket.userId;
        socket.join(roomName);
        console.log('USER vao room:', roomName);
    }

    socket.on('join-room', function (data) {
        if (socket.roleName !== 'ADMIN') {
            return socket.emit('error-message', { message: 'Ban khong co quyen vao room nay' });
        }

        let userId = data && data.userId;
        if (!userId) {
            return socket.emit('error-message', { message: 'Thieu userId' });
        }

        let roomName = 'user_' + userId;
        socket.join(roomName);

        socket.emit('joined-room', {
            room: roomName,
            userId: userId
        });

        console.log('ADMIN vao room:', roomName);
    });

    // callback la ack de client biet server da nhan va luu tin nhan
    socket.on('send-message', async function (data, callback) {
        try {
            let content = data && data.content ? data.content.trim() : '';
            let clientMessageId = data && data.clientMessageId ? data.clientMessageId.trim() : '';
            if (!content) {
                if (typeof callback === 'function') {
                    callback({ ok: false, message: 'Noi dung khong duoc de trong' });
                }
                return socket.emit('error-message', { message: 'Noi dung khong duoc de trong' });
            }

            let targetUserId;

            if (socket.roleName === 'USER') {
                targetUserId = socket.userId;
            } else if (socket.roleName === 'ADMIN') {
                targetUserId = data.userId;
                if (!targetUserId) {
                    if (typeof callback === 'function') {
                        callback({ ok: false, message: 'Admin phai gui kem userId' });
                    }
                    return socket.emit('error-message', { message: 'Admin phai gui kem userId' });
                }
            } else {
                if (typeof callback === 'function') {
                    callback({ ok: false, message: 'Role khong hop le' });
                }
                return socket.emit('error-message', { message: 'Role khong hop le' });
            }

            let result = await chatsService.createMessage(
                targetUserId,
                socket.userId,
                socket.roleName,
                content,
                clientMessageId
            );

            let newMessage = result.message;

            // Emit ngay lập tức TRƯỚC khi populate để giảm độ trễ
            if (result.created) {
                let roomName = 'user_' + targetUserId;
                io.to(roomName).emit('new-message', newMessage);
            }

            // Populate sau emit (dùng cho callback, không ảnh hưởng tốc độ nhận tin nhắn)
            await newMessage.populate({
                path: 'sender',
                select: 'username fullName role'
            });

            if (typeof callback === 'function') {
                callback({
                    ok: true,
                    messageId: newMessage._id,
                    clientMessageId: newMessage.clientMessageId || clientMessageId,
                    created: result.created
                });
            }

            if (result.created) {
                Promise.resolve().then(async function () {
                    let senderName = socket.displayName || 'User';

                    if (socket.roleName === 'USER') {
                        io.to('notification_admins').emit('new-notification', {
                            title: 'Tin nhan moi',
                            content: senderName + ' vua gui tin nhan',
                            type: 'CHAT',
                            link: '/admin/',
                            isRead: false,
                            createdAt: new Date().toISOString()
                        });

                        let users = await userModel.find({ isDeleted: false })
                            .select('_id role')
                            .populate({ path: 'role', select: 'name' });

                        let adminUsers = users.filter(function (item) {
                            return item.role && item.role.name === 'ADMIN';
                        });

                        await Promise.all(adminUsers.map(async function (admin) {
                            await notificationsService.create({
                                user: admin._id,
                                title: 'Tin nhan moi',
                                content: senderName + ' vua gui tin nhan',
                                type: 'CHAT',
                                link: '/admin/'
                            });
                        }));
                    } else if (socket.roleName === 'ADMIN') {
                        io.to('notification_' + targetUserId).emit('new-notification', {
                            title: 'Admin da tra loi',
                            content: senderName + ' vua tra loi tin nhan cua ban',
                            type: 'CHAT',
                            link: '/chat/',
                            isRead: false,
                            createdAt: new Date().toISOString()
                        });

                        await notificationsService.create({
                            user: targetUserId,
                            title: 'Admin da tra loi',
                            content: senderName + ' vua tra loi tin nhan cua ban',
                            type: 'CHAT',
                            link: '/chat/'
                        });
                    }
                }).catch(function (err) {
                    console.error('Tao notification chat that bai:', err.message);
                });
            }
        } catch (err) {
            if (typeof callback === 'function') {
                callback({ ok: false, message: err.message });
            }
            socket.emit('error-message', { message: err.message });
        }
    });

    socket.on('disconnect', function () {
        console.log('Socket da ngat:', socket.userId);
    });
});

server.listen(port);

server.on('listening', function () {
    console.log('Server chay tai http://localhost:' + port);
});

server.on('error', function (error) {
    if (error.code === 'EADDRINUSE') {
        console.error('Port ' + port + ' dang bi chiem');
        process.exit(1);
    } else {
        throw error;
    }
});
