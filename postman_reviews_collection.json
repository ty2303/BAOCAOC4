{
  "info": {
    "name": "BAOCAO REVIEWS API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "REVIEWS",
      "item": [
        {
          "name": "GET reviews by product",
          "request": {
            "method": "GET",
            "url": "http://localhost:3000/api/v1/reviews/product/{{product_id}}"
          }
        },
        {
          "name": "POST create review (USER)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "http://localhost:3000/api/v1/reviews",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"product\": \"{{product_id}}\",\n  \"rating\": 5,\n  \"comment\": \"San pham tot, dung nhu mo ta\"\n}"
            }
          }
        },
        {
          "name": "DELETE review (ADMIN)",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "url": "http://localhost:3000/api/v1/reviews/{{review_id}}"
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "token",
      "value": "PASTE_TOKEN_HERE",
      "description": "Thay bang token USER nhan duoc sau khi login"
    },
    {
      "key": "admin_token",
      "value": "PASTE_ADMIN_TOKEN_HERE",
      "description": "Thay bang token ADMIN nhan duoc sau khi login"
    },
    {
      "key": "product_id",
      "value": "PASTE_PRODUCT_ID_HERE",
      "description": "Thay bang _id cua product sau khi tao"
    },
    {
      "key": "review_id",
      "value": "PASTE_REVIEW_ID_HERE",
      "description": "Thay bang _id cua review can xoa"
    }
  ]
}
